{
  "name": "atmospheris",
  "version": "0.1.0",
  "description": "ISO 2533 Standard Atmosphere & ISO 5878 Reference Atmospheres — TypeScript/JavaScript reference implementation",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
